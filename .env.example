# ===========================================
# BLENDiT Backend - Environment Variables
# ===========================================
# Copy to .env and fill in values

# Database (required)
DATABASE_URL="postgresql://postgres:password@localhost:5432/blendit"

# JWT
JWT_SECRET="your-secret-key"
JWT_EXPIRATION="720h"

# Server
PORT=7000
PRISMA_CONNECT_ON_STARTUP="true"

# Seed (optional - for `npx prisma db seed`)
SEED_ADMIN_EMAIL=admin@blendit.com
SEED_ADMIN_PASSWORD=Admin@123
